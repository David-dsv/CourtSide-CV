# Environment variables for CourtSide-CV.
# Copy this file to `.env` and fill in your own values. `.env` is gitignored —
# never commit real keys.

# Roboflow API key — used only by training/train_roboflow_yolo26.py to download
# the tennis-ball dataset. Get one at https://app.roboflow.com → Settings → API.
ROBOFLOW_API_KEY=
