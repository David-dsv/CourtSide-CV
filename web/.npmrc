# CourtSide frontend — local pnpm overrides
# The user's global pnpm config is security-hardened (trust-policy=no-downgrade,
# minimum-release-age=14400s). For this frontend sandbox we relax only the
# trust-downgrade abort (report instead) so @types/node's transitive
# undici-types can install. Local to web/ only — does not touch global config.
trust-policy=report
min-release-age=0
